# ── Risk analyst (Claude) ────────────────────────
# Required for real risk scoring. Without it the app still runs and records
# events, but every riskScore is 0 (it logs one warning).
ANTHROPIC_API_KEY=sk-ant-...

# Model used to rate each event. Default is fast + cheap for per-event judging.
# Use claude-opus-4-8 for maximum quality, claude-haiku-4-5-20251001 for lowest cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Hook auth ────────────────────────────────────
# Maps a hook API key -> the user it belongs to. JSON object, key = the bearer
# token a user puts in $CODESENTINEL_KEY, value = that user's identity.
# Leave unset to use the built-in dev key "cs_dev_local".
CODESENTINEL_KEYS={"cs_dev_local":{"id":"u_demo","name":"Demo User","team":"Ops","email":"demo@local","orgId":"org_demo"}}

# ── Enforcement ──────────────────────────────────
# When "true", a PreToolUse event the analyst rates with a CRITICAL flag is
# denied (Claude Code refuses the tool call). Default is flag-only.
CS_BLOCK_CRITICAL=false
